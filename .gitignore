build/
out/
.vs/
*.user

# Derived mip-chain textures (regenerate with AssetBaker mips)
assets/textures/*.dds

# Scanned texture sets are fetched from OneDrive\DungeonAssets, not committed
# (tools/FetchTextures.ps1). The raw Poly Haven downloads live there too.
assets/textures/*.png
docs/*.png

# Authored multi-material models (bought packs) carry embedded textures, so the
# .glb is heavy — regenerated from OneDrive\DungeonAssets by tools/FetchModels.ps1
# (committed models stay .gltf). See the fab.com mesh pipeline.
assets/models/*.glb

# Temp file for git commit -F (never track)
.git-commit-msg.txt
__pycache__/

# Generated animation-catalog snippets (ImportAnimLibrary --catalog-out)
assets/models/*.anim.cat

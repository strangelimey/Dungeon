; Ceiling surface types: texture set + worn-block height displacement.

[ceiling_rough]
display = Rough
texture = ceiling_rough
height_scale = 0.035

[ceiling_cracked]
display = Cracked
texture = ceiling_cracked
height_scale = 0.035

; --- scanned sets from textures.com (1k/2k/4k installed) ---
[ceiling_stone]
display = Stone
texture = limestone
height_scale = 0.035

[ceiling_plaster]
display = Plaster
texture = plaster
height_scale = 0.03

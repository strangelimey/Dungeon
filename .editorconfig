root = true

[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

# All project code indents with tabs (rendered 4 wide).
[*.{cpp,h,hlsl,cmake,json}]
indent_style = tab
indent_size = 4
tab_width = 4

[CMakeLists.txt]
indent_style = tab
tab_width = 4

# Markdown: spaces (tabs change list/code semantics), keep trailing breaks.
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
